<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Label="Globals">
    <VCProjectVersion>16.0</VCProjectVersion>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
  </PropertyGroup>

  <!-- SDL3 (core via ObjectivelyGPU, plus SDL3_image and SDL3_ttf from
       ObjectivelyMVC) is fetched on demand by this imported targets file, which
       defines $(SDL3Dir), $(SDL3ImageDir), $(SDL3TtfDir) and $(SDL3LibArch). -->
  <Import Project="..\..\ObjectivelyMVC\ObjectivelyMVC.vs15\sdl3.targets" />

  <!-- This props file is imported before Microsoft.Cpp.props, which only sets
       the default Include/LibraryPath (Windows SDK + CRT dirs) when they are
       empty.  sdl3.targets prepends SDL3 to those paths, which would suppress
       the toolset defaults, so clear them here; the toolset then repopulates
       them and Quetoo adds SDL3 via $(QuetooFull*Path) below. -->
  <PropertyGroup>
    <IncludePath></IncludePath>
    <LibraryPath></LibraryPath>
  </PropertyGroup>

  <PropertyGroup Label="Configuration">
    <CharacterSet>MultiByte</CharacterSet>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)'=='Release'" Label="Configuration">
    <UseDebugLibraries>false</UseDebugLibraries>
    <WholeProgramOptimization>true</WholeProgramOptimization>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)'=='Debug'" Label="Configuration">
    <UseDebugLibraries>true</UseDebugLibraries>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Platform)'=='x64'">
    <UseNativeEnvironment>true</UseNativeEnvironment>
  </PropertyGroup>

  <PropertyGroup Label="Configuration">
    <PlatformToolset>ClangCL</PlatformToolset>
    <QuetooOutDir>bin\$(Platform)$(Configuration)\</QuetooOutDir>
    <QuetooIntDir>tmp\$(MSBuildProjectName)\$(Platform)$(Configuration)\</QuetooIntDir>

    <UseMultiToolTask>true</UseMultiToolTask>
    <WholeProgramOptimization>false</WholeProgramOptimization>
  </PropertyGroup>

  <PropertyGroup Label="Configuration" Condition="'$(Platform)'=='x64'">
    <PreferredToolArchitecture>x64</PreferredToolArchitecture>
  </PropertyGroup>

  <PropertyGroup Label="UserMacros">
    <QuetooObjectivelyPath>$(SolutionDir)..\..\Objectively\</QuetooObjectivelyPath>
    <QuetooObjectivelyWinPath>$(QuetooObjectivelyPath)Objectively.vs15\</QuetooObjectivelyWinPath>
    <QuetooObjectivelyLibsPath>$(QuetooObjectivelyWinPath)libs\</QuetooObjectivelyLibsPath>
    <QuetooObjectivelyIncludePath>$(QuetooObjectivelyPath)Sources\;$(QuetooObjectivelyWinPath)Sources\;$(QuetooObjectivelyWinPath)Sources\gnu\</QuetooObjectivelyIncludePath>
    <QuetooObjectivelyLibraryPath>$(QuetooObjectivelyWinPath)bin\$(Platform)$(Configuration)\</QuetooObjectivelyLibraryPath>

    <QuetooObjectivelyGPUPath>$(SolutionDir)..\..\ObjectivelyGPU\</QuetooObjectivelyGPUPath>
    <QuetooObjectivelyGPUWinPath>$(QuetooObjectivelyGPUPath)ObjectivelyGPU.vs15\</QuetooObjectivelyGPUWinPath>
    <QuetooObjectivelyGPULibsPath>$(QuetooObjectivelyGPUWinPath)libs\</QuetooObjectivelyGPULibsPath>
    <QuetooObjectivelyGPUIncludePath>$(QuetooObjectivelyGPUPath)Sources\;$(QuetooObjectivelyGPUWinPath)Sources\</QuetooObjectivelyGPUIncludePath>
    <QuetooObjectivelyGPULibraryPath>$(QuetooObjectivelyGPUWinPath)bin\$(Platform)$(Configuration)\</QuetooObjectivelyGPULibraryPath>

    <QuetooObjectivelyMVCPath>$(SolutionDir)..\..\ObjectivelyMVC\</QuetooObjectivelyMVCPath>
    <QuetooObjectivelyMVCWinPath>$(QuetooObjectivelyMVCPath)ObjectivelyMVC.vs15\</QuetooObjectivelyMVCWinPath>
    <QuetooObjectivelyMVCLibsPath>$(QuetooObjectivelyMVCWinPath)libs\</QuetooObjectivelyMVCLibsPath>
    <QuetooObjectivelyMVCIncludePath>$(QuetooObjectivelyMVCPath)Sources\;$(QuetooObjectivelyMVCWinPath)Sources\</QuetooObjectivelyMVCIncludePath>
    <QuetooObjectivelyMVCLibraryPath>$(QuetooObjectivelyMVCWinPath)bin\$(Platform)$(Configuration)\</QuetooObjectivelyMVCLibraryPath>

    <QuetooPath>$(SolutionDir)..\</QuetooPath>
    <QuetooWinPath>$(SolutionDir)</QuetooWinPath>
    <QuetooLibsPath>$(SolutionDir)libs\</QuetooLibsPath>
    <QuetooIncludePath>$(QuetooPath);$(QuetooPath)src\;$(QuetooWinPath)src\</QuetooIncludePath>
    <QuetooLibraryPath>$(QuetooLibsPath)bin\$(Platform)$(Configuration)\</QuetooLibraryPath>

    <QuetooCursesPath>$(QuetooLibsPath)curses\</QuetooCursesPath>
    <QuetooCursesIncludePath>$(QuetooCursesPath)</QuetooCursesIncludePath>
    <QuetooCursesLibraryPath>$(QuetooCursesPath)lib\$(Platform)\</QuetooCursesLibraryPath>

    <QuetooPhysFSPath>$(QuetooLibsPath)physfs\</QuetooPhysFSPath>
    <QuetooPhysFSIncludePath>$(QuetooPhysFSPath)</QuetooPhysFSIncludePath>
    <QuetooPhysFSLibraryPath>$(QuetooPhysFSPath)bin\$(Platform)\</QuetooPhysFSLibraryPath>
    <QuetooPhysFSDefs>PHYSFS_DECL=;alloca=_alloca;utime=_utime;utimbuf=_utimbuf;PHYSFS_SUPPORTS_ZIP=1;PHYSFS_SUPPORTS_7Z=0;PHYSFS_SUPPORTS_GRP=0;PHYSFS_SUPPORTS_HOG=0;PHYSFS_SUPPORTS_MVL=0;PHYSFS_SUPPORTS_WAD=0;PHYSFS_SUPPORTS_QPAK=1;PHYSFS_SUPPORTS_SLB=0;PHYSFS_SUPPORTS_ISO9660=0;PHYSFS_SUPPORTS_VDF=0</QuetooPhysFSDefs>

    <QuetooLibXMLPath>$(QuetooLibsPath)xml\</QuetooLibXMLPath>
    <QuetooLibXMLIncludePath>$(QuetooLibXMLPath)include\</QuetooLibXMLIncludePath>
    <QuetooLibXMLLibraryPath>$(QuetooLibXMLPath)lib\$(Platform)\</QuetooLibXMLLibraryPath>

    <QuetooPthreadPath>$(QuetooObjectivelyLibsPath)pthread\</QuetooPthreadPath>
    <QuetooPthreadIncludePath>$(QuetooPthreadPath)include\</QuetooPthreadIncludePath>
    <QuetooPthreadLibraryPath>$(QuetooPthreadPath)lib\$(Platform)\</QuetooPthreadLibraryPath>

    <QuetooDLFCNIncludePath>$(QuetooObjectivelyLibsPath)dlfcn\</QuetooDLFCNIncludePath>
    <QuetooDLFCNLibraryPath>$(QuetooDLFCNIncludePath)$(Platform)\</QuetooDLFCNLibraryPath>

    <QuetooIconvPath>$(QuetooObjectivelyLibsPath)iconv\</QuetooIconvPath>
    <QuetooIconvIncludePath>$(QuetooIconvPath)include\</QuetooIconvIncludePath>
    <QuetooIconvLibraryPath>$(QuetooIconvPath)lib\$(Platform)\</QuetooIconvLibraryPath>

    <QuetooCURLPath>$(QuetooObjectivelyLibsPath)curl\</QuetooCURLPath>
    <QuetooCURLIncludePath>$(QuetooCURLPath)include\</QuetooCURLIncludePath>
    <QuetooCURLLibraryPath>$(QuetooCURLPath)lib\$(Platform)\</QuetooCURLLibraryPath>

    <QuetooFontConfigPath>$(QuetooObjectivelyMVCLibsPath)fontconfig\</QuetooFontConfigPath>
    <QuetooFontConfigIncludePath>$(QuetooFontConfigPath)</QuetooFontConfigIncludePath>
    <QuetooFontConfigLibraryPath>$(QuetooFontConfigPath)lib\$(Platform)\</QuetooFontConfigLibraryPath>

    <QuetooFreeTypePath>$(QuetooObjectivelyMVCLibsPath)freetype\</QuetooFreeTypePath>
    <QuetooFreeTypeIncludePath></QuetooFreeTypeIncludePath>
    <QuetooFreeTypeLibraryPath>$(QuetooFreeTypePath)lib\$(Platform)\</QuetooFreeTypeLibraryPath>

    <!-- SDL3 search paths come from the imported sdl3.targets (downloaded on demand). -->
    <QuetooSDLIncludePath>$(SDL3Dir)include\</QuetooSDLIncludePath>
    <QuetooSDLLibraryPath>$(SDL3Dir)lib\$(SDL3LibArch)\</QuetooSDLLibraryPath>

    <QuetooSDLTTFIncludePath>$(SDL3TtfDir)include\</QuetooSDLTTFIncludePath>
    <QuetooSDLTTFLibraryPath>$(SDL3TtfDir)lib\$(SDL3LibArch)\</QuetooSDLTTFLibraryPath>

    <QuetooSDLImageIncludePath>$(SDL3ImageDir)include\</QuetooSDLImageIncludePath>
    <QuetooSDLImageLibraryPath>$(SDL3ImageDir)lib\$(SDL3LibArch)\</QuetooSDLImageLibraryPath>

    <QuetoolibsndfilePath>$(QuetooLibsPath)libsndfile\</QuetoolibsndfilePath>
    <QuetoolibsndfileIncludePath>$(QuetoolibsndfilePath)\include</QuetoolibsndfileIncludePath>
    <QuetoolibsndfileLibraryPath>$(QuetoolibsndfilePath)$(Platform)\</QuetoolibsndfileLibraryPath>

    <OpenALPath>$(QuetooLibsPath)openal</OpenALPath>
    <OpenALIncludePath>$(OpenALPath)\</OpenALIncludePath>
    <OpenALLibraryPath>$(OpenALPath)\libs\$(Platform)\</OpenALLibraryPath>

	<DepsIncludePath>$(QuetooPath)deps\rapidjson\;$(QuetooPath)deps\discord-rpc\include\</DepsIncludePath>

    <QuetooFullIncludePath>$(DepsIncludePath);$(OpenALIncludePath);$(QuetooIncludePath);$(QuetooPath)src\client\;$(QuetooPath)src\client\ui\;$(QuetooPath)src\cgame\default\;$(QuetooPath)src\cgame\default\ui\teams\;$(QuetooPath)src\cgame\default\ui\common\;$(QuetooPath)src\cgame\default\ui\credits\;$(QuetooPath)src\cgame\default\ui\home\;$(QuetooPath)src\cgame\default\ui\main\;$(QuetooPath)src\cgame\default\ui\play\;$(QuetooPath)src\cgame\default\ui\controls\;$(QuetooPath)src\cgame\default\ui\settings\;$(QuetooObjectivelyIncludePath);$(QuetooObjectivelyGPUIncludePath);$(QuetooObjectivelyMVCIncludePath);$(QuetooPthreadIncludePath);$(QuetooIconvIncludePath);$(QuetooCURLIncludePath);$(QuetooLibXMLIncludePath);$(QuetooPhysFSIncludePath);$(QuetooZlibIncludePath);$(QuetooCursesIncludePath);$(QuetooFontConfigIncludePath);$(QuetooFreeTypeIncludePath);$(QuetooSDLIncludePath);$(QuetooSDLTTFIncludePath);$(QuetooSDLImageIncludePath);$(QuetoolibsndfileIncludePath);$(QuetooDLFCNIncludePath)</QuetooFullIncludePath>
    <QuetooFullLibraryPath>$(OpenALLibraryPath);$(QuetooLibraryPath);$(QuetooObjectivelyLibraryPath);$(QuetooObjectivelyGPULibraryPath);$(QuetooObjectivelyMVCLibraryPath);$(QuetooPthreadLibraryPath);$(QuetooIconvLibraryPath);$(QuetooCURLLibraryPath);$(QuetooLibXMLLibraryPath);$(QuetooPhysFSLibraryPath);$(QuetooCursesLibraryPath);$(QuetooFontConfigLibraryPath);$(QuetooFreeTypeLibraryPath);$(QuetooSDLLibraryPath);$(QuetooSDLTTFLibraryPath);$(QuetooSDLImageLibraryPath);$(QuetoolibsndfileLibraryPath);$(QuetooDLFCNLibraryPath)</QuetooFullLibraryPath>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <WarningLevel>EnableAllWarnings</WarningLevel>
      <SDLCheck>true</SDLCheck>
      <PreprocessorDefinitions>$(ExtraPreprocessorDefinitions);$(QuetooPhysFSDefs);HAVE_DLFCN_H=1;WIN32_LEAN_AND_MEAN;SDL_MAIN_HANDLED;NOCRYPT;CURL_STATICLIB;HAVE_STRUCT_TIMESPEC=1;_CRT_SECURE_NO_WARNINGS;__clang__;_CRT_DECLARE_NONSTDC_NAMES=0;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <CLanguageStandard>gnu17</CLanguageStandard>
 	  <AdditionalOptions>%(AdditionalOptions) -ferror-limit=0 -fmacro-backtrace-limit=0 -Wno-trigraphs -Wmissing-field-initializers -Wno-missing-prototypes -Wunreachable-code -Wmissing-braces -Wparentheses -Wswitch -Wunused-function -Wunused-label -Wno-unused-parameter -Wunused-variable -Wunused-value -Wempty-body -Wuninitialized -Wno-unknown-pragmas -Wno-shadow -Wno-four-char-constants -Wno-conversion -Wconstant-conversion -Wint-conversion -Wbool-conversion -Wenum-conversion -Wno-float-conversion -Wnon-literal-null-conversion -Wno-objc-literal-conversion -Wsign-compare -Wshorten-64-to-32 -Wpointer-sign -Wno-newline-eof -fstrict-aliasing -Wno-sign-conversion -Winfinite-recursion -Wno-block-capture-autoreleasing -Wstrict-prototypes -Wno-semicolon-before-method-body -Wno-documentation -Wno-dollar-in-identifier-extension -Wno-gnu-statement-expression -Wno-extra-semi-stmt -Wno-language-extension-token -Wno-switch-enum -Wno-covered-switch-default -Wno-gnu-zero-variadic-macro-arguments -Wno-reserved-id-macro -Wno-date-time -Wno-documentation-unknown-command -Wno-gnu-conditional-omitted-operand -Wno-undef -Wno-vla -Wno-cast-align -Wno-assign-enum -Wno-disabled-macro-expansion -Wno-zero-length-array -Wno-cast-qual -Wno-double-promotion -Wno-float-equal -Wno-bad-function-cast -Wno-comma -Wno-tautological-type-limit-compare -Wno-unused-macros -Wno-nonportable-system-include-path -Wno-gnu-empty-initializer -Wno-reserved-identifier -Wno-declaration-after-statement -Wno-unsafe-buffer-usage -Wno-cast-function-type-strict -Wno-switch-default -Wno-implicit-fallthrough -Wno-gnu-pointer-arith -Wno-enum-float-conversion -Wno-conditional-uninitialized -Wno-format-nonliteral -Wno-format -Wno-incompatible-function-pointer-types-strict -Wno-gnu-case-range -Wno-deprecated-declarations -Wno-pre-c11-compat -Wno-pedantic -Wno-c23-extensions -Wno-implicit-int-float-conversion -Wno-c++98-compat -Wno-c++98-compat-pedantic -Wno-old-style-cast -Wno-global-constructors -Wno-zero-as-null-pointer-constant -Wno-macro-redefined</AdditionalOptions>
    </ClCompile>
    <Link>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <FullProgramDatabaseFile>true</FullProgramDatabaseFile>
    </Link>
  </ItemDefinitionGroup>

  <ItemDefinitionGroup Condition="'$(Configuration)'=='Debug'">
    <ClCompile>
      <Optimization>Disabled</Optimization>
    </ClCompile>
  </ItemDefinitionGroup>

  <ItemDefinitionGroup Condition="'$(Configuration)'=='Release'">
    <ClCompile>
      <Optimization>MaxSpeed</Optimization>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>
      <DebugInformationFormat>ProgramDatabase</DebugInformationFormat>
    </ClCompile>
    <Link>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>
      <GenerateDebugInformation>ProgramDatabase</GenerateDebugInformation>
    </Link>
  </ItemDefinitionGroup>

  <ItemGroup>
      <BuildMacro Include="QuetooOutDir"><Value>$(QuetooOutDir)</Value></BuildMacro>
      <BuildMacro Include="QuetooIntDir"><Value>$(QuetooIntDir)</Value></BuildMacro>

      <BuildMacro Include="QuetooFullIncludePath"><Value>$(QuetooFullIncludePath)</Value></BuildMacro>
      <BuildMacro Include="QuetooFullLibraryPath"><Value>$(QuetooFullLibraryPath)</Value></BuildMacro>
  </ItemGroup>
</Project>
