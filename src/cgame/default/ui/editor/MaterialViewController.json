{
  "identifier": "material",
  "subviews": [
    {
      "class": "StackView",
      "identifier": "materialContent",
      "classNames": [
        "container"
      ],
      "subviews": [
        {
          "class": "Box",
          "identifier": "materialBox",
          "label": {
            "text": {
              "text": "Material"
            }
          },
          "contentView": {
            "subviews": [
              {
                "class": "KeyValueTableView",
                "classNames": [
                  "kvTable"
                ],
                "subviews": [
                  {
                    "class": "KeyValueView",
                    "key": { "class": "Label", "text": { "text": "Diffusemap" } },
                    "value": { "class": "TextView", "identifier": "diffusemap" }
                  },
                  {
                    "class": "KeyValueView",
                    "key": { "class": "Label", "text": { "text": "Normalmap" } },
                    "value": { "class": "TextView", "identifier": "normalmap" }
                  },
                  {
                    "class": "KeyValueView",
                    "key": { "class": "Label", "text": { "text": "Specularmap" } },
                    "value": { "class": "TextView", "identifier": "specularmap" }
                  }
                ]
              }
            ]
          }
        },
        {
          "class": "Box",
          "identifier": "pbrBox",
          "label": {
            "text": {
              "text": "PBR Settings"
            }
          },
          "contentView": {
            "subviews": [
              {
                "class": "KeyValueTableView",
                "classNames": [
                  "kvTable"
                ],
                "subviews": [
                  {
                    "class": "KeyValueView",
                    "key": { "class": "Label", "text": { "text": "Roughness" } },
                    "value": { "class": "Slider", "identifier": "roughness", "min": 0, "max": 8, "step": 0.125 }
                  },
                  {
                    "class": "KeyValueView",
                    "key": { "class": "Label", "text": { "text": "Parallax" } },
                    "value": { "class": "Slider", "identifier": "parallax", "min": 0, "max": 8, "step": 0.125 }
                  },
                  {
                    "class": "KeyValueView",
                    "key": { "class": "Label", "text": { "text": "Shadow" } },
                    "value": { "class": "Slider", "identifier": "shadow", "min": 0, "max": 8, "step": 0.125 }
                  },
                  {
                    "class": "KeyValueView",
                    "key": { "class": "Label", "text": { "text": "Hardness" } },
                    "value": { "class": "Slider", "identifier": "hardness", "min": 0, "max": 8, "step": 0.125 }
                  },
                  {
                    "class": "KeyValueView",
                    "key": { "class": "Label", "text": { "text": "Specularity" } },
                    "value": { "class": "Slider", "identifier": "specularity", "min": 0, "max": 8, "step": 0.125 }
                  },
                  {
                    "class": "KeyValueView",
                    "key": { "class": "Label", "text": { "text": "Alpha test" } },
                    "value": { "class": "Slider", "identifier": "alpha_test", "min": 0, "max": 1, "step": 0.05 }
                  }
                ]
              }
            ]
          }
        },
        {
          "class": "Box",
          "identifier": "stagesBox",
          "classNames": [
            "stagesBox"
          ],
          "label": {
            "text": {
              "text": "Material Stages"
            }
          },
          "contentView": {
            "subviews": [
              {
                "class": "StackView",
                "classNames": [
                  "stagesHeader"
                ],
                "subviews": [
                  {
                    "class": "Button",
                    "identifier": "addStage",
                    "classNames": [
                      "addStage"
                    ],
                    "title": {
                      "text": "+ Add Stage"
                    }
                  }
                ]
              },
              {
                "class": "StackView",
                "identifier": "stages",
                "classNames": [
                  "stages"
                ]
              }
            ]
          }
        }
