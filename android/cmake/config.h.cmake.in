/*
 * config.h — generated by the Quetoo CMake build (android/CMakeLists.txt).
 *
 * The autotools build generates this via AC_CONFIG_HEADERS(config.h) from
 * configure.ac. The CMake build does not run configure, so we synthesize an
 * equivalent here via configure_file(). src/quetoo.h includes "config.h"
 * unconditionally, so every translation unit sees these.
 *
 * Keep the set of macros in sync with the AC_DEFINE_UNQUOTED calls in
 * configure.ac (BUILD, VERSION, BINDIR, PKGLIBDIR, PKGDATADIR) plus the
 * optional feature probes (HAVE_EXECINFO).
 *
 * DO NOT edit the generated file; edit this template
 * (android/cmake/config.h.cmake.in) instead.
 */
#ifndef QUETOO_CONFIG_H
#define QUETOO_CONFIG_H

/* The canonical name of the build (configure.ac: ${host_cpu}-${host_vendor}-${host_os}).
 * For Android we synthesize "<abi>-android". */
#define BUILD "@QUETOO_BUILD@"

/* The game version number (configure.ac default: -1, which disables the installer). */
#define VERSION "@QUETOO_VERSION@"

/* AC_INIT package identity (autotools auto-defines these; the engine uses
 * PACKAGE_STRING for the window title in r_context.c, etc.). */
#define PACKAGE "quetoo"
#define PACKAGE_NAME "Quetoo"
#define PACKAGE_TARNAME "quetoo"
#define PACKAGE_VERSION "@QUETOO_VERSION@"
#define PACKAGE_STRING "Quetoo @QUETOO_VERSION@"
#define PACKAGE_BUGREPORT "ports@quetoo.org"
#define PACKAGE_URL "https://quetoo.org"

/* Install/runtime paths. On Android these are not real FS paths the way they
 * are on desktop (game data is loaded from the APK assets / SDL_GetPrefPath at
 * runtime — see PORTING.md §4). They are defined to keep the engine compiling;
 * filesystem.c / sys.c consume them. Override via -DQUETOO_* if a packaging
 * step needs specific values. */
#define BINDIR "@QUETOO_BINDIR@"
#define PKGLIBDIR "@QUETOO_PKGLIBDIR@"
#define PKGDATADIR "@QUETOO_PKGDATADIR@"

/* <execinfo.h> backtrace support. Bionic (Android) does NOT provide execinfo,
 * so this is left undefined there; glibc desktop builds define it. */
#cmakedefine HAVE_EXECINFO 1

/* Header availability (autotools AC_CHECK_HEADERS). All present on Android/Bionic
 * and Linux; quetoo.h gates <unistd.h> on HAVE_UNISTD_H, etc. */
#define HAVE_UNISTD_H 1
#define HAVE_SYS_TIME_H 1
#define HAVE_DLFCN_H 1

#endif /* QUETOO_CONFIG_H */
